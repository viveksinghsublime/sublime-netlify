# Legacy external API base URL is no longer used by the app.
# NEXT_PUBLIC_BASE_URL=https://api.samiinfotech.com/

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

ADMIN_NAME=Sublime Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASS=your-mailgun-smtp-password
SMTP_FROM=noreply@yourdomain.com

# CONTACT_RECIPIENTS=sales@yourdomain.com,info@yourdomain.com
CONTACT_RECIPIENTS=team@yourdomain.com
JOB_APPLICATION_RECIPIENTS=hr@yourdomain.com

NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
# Leave empty for development. On production set to: yourdomain.com
TURNSTILE_EXPECTED_HOSTNAME=
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_SECONDS=3600
